---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

interface Props {
  title: string;
  description: string;
  heading: string;
  path: string;
  lastUpdated: string;
}
const { title, description, heading, path, lastUpdated } = Astro.props;
---

<BaseLayout title={title} description={description} noindex={false}>
  <Breadcrumbs items={[{ name: heading, path }]} />
  <article class="container-rm py-14 md:py-20">
    <div class="mx-auto max-w-prose">
      <div class="accent-rule mb-4"></div>
      <h1 class="text-h1">{heading}</h1>
      <p class="mt-3 text-sm text-ink-muted">Última actualización: {lastUpdated}</p>
      <div class="prose-rm mt-8">
        <slot />
      </div>
    </div>
  </article>
</BaseLayout>
