---
import { SITE } from '../data/site';
interface Props {
  title?: string;
  text?: string;
}
const {
  title = '¿Necesita auditar sus cuentas o justificar una subvención?',
  text = 'Cuéntenos su caso sin compromiso. Le indicaremos si el trabajo es obligatorio, qué alcance tiene y qué documentación necesitará, con un presupuesto cerrado.',
} = Astro.props;
---

<section class="mt-24">
  <div class="container-rm">
    <div class="overflow-hidden rounded-card bg-brand-800 px-6 py-12 text-center sm:px-12 md:py-16">
      <div class="mx-auto max-w-2xl">
        <div class="accent-rule mx-auto mb-5"></div>
        <h2 class="font-serif text-h2 text-white">{title}</h2>
        <p class="mx-auto mt-4 max-w-xl text-lg leading-relaxed text-sand-200/90">{text}</p>
        <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
          <a href="/contacto" class="btn bg-white text-brand-800 hover:bg-sand-100 hover:text-brand-900">
            Solicitar presupuesto
          </a>
          <a
            href={`tel:${SITE.phoneHref}`}
            class="btn border border-white/30 text-white hover:bg-white/10 hover:text-white"
          >
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
            </svg>
            {SITE.phoneDisplay}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
