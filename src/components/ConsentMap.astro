---
/**
 * Mapa de ubicación con consentimiento previo (RGPD/LSSI-CE).
 * No carga ningún recurso de Google hasta que el usuario lo autoriza, ya sea
 * desde el banner de cookies o desde el botón de este propio bloque.
 */
import { SITE } from '../data/site';

const query = encodeURIComponent(
  `${SITE.name}, ${SITE.address.street}, ${SITE.address.postalCode} ${SITE.address.city}`.replace(/\{\{[^}]*\}\}/g, '').replace(/\s+,/g, ',').trim()
);
// Embed público de Google Maps (no requiere API key).
const mapSrc = `https://www.google.com/maps?q=${query || encodeURIComponent('Burgos')}&output=embed`;
const mapsLink = `https://www.google.com/maps/search/?api=1&query=${query || encodeURIComponent('Burgos')}`;
---

<div
  id="map-container"
  class="relative aspect-[16/10] w-full overflow-hidden rounded-card border border-sand-200 bg-sand-100"
  data-map-src={mapSrc}
  data-maps-link={mapsLink}
>
  <!-- Marcador de posición mientras no hay consentimiento -->
  <div id="map-placeholder" class="absolute inset-0 flex flex-col items-center justify-center gap-4 p-6 text-center">
    <svg class="h-10 w-10 text-brand-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
    </svg>
    <p class="max-w-sm text-sm text-ink-soft">
      Para mostrar el mapa cargamos Google Maps, un servicio de terceros que puede instalar
      cookies. Active el contenido externo para verlo.
    </p>
    <button id="map-load" type="button" class="btn btn-primary py-2.5 text-sm">
      Cargar mapa
    </button>
    <a id="map-external" href={mapsLink} target="_blank" rel="noopener noreferrer" class="text-sm font-medium underline">
      Abrir en Google Maps (nueva pestaña)
    </a>
  </div>
</div>

<script>
  const KEY = 'rm-consent';
  const container = document.getElementById('map-container');

  function loadMap() {
    if (!container || container.dataset.loaded === 'true') return;
    const src = container.dataset.mapSrc;
    if (!src) return;
    const iframe = document.createElement('iframe');
    iframe.src = src;
    iframe.title = 'Mapa de ubicación de Ruiz & Marín en Burgos';
    iframe.loading = 'lazy';
    iframe.referrerPolicy = 'no-referrer-when-downgrade';
    iframe.className = 'absolute inset-0 h-full w-full border-0';
    iframe.setAttribute('allowfullscreen', '');
    container.querySelector('#map-placeholder')?.remove();
    container.appendChild(iframe);
    container.dataset.loaded = 'true';
  }

  function hasMapConsent(): boolean {
    try {
      const raw = localStorage.getItem(KEY);
      return raw ? !!JSON.parse(raw).map : false;
    } catch {
      return false;
    }
  }

  // Botón propio: concede consentimiento al mapa y lo carga.
  document.getElementById('map-load')?.addEventListener('click', () => {
    try {
      localStorage.setItem(KEY, JSON.stringify({ map: true, ts: new Date().toISOString() }));
    } catch {
      /* sin persistencia */
    }
    document.dispatchEvent(new CustomEvent('rm:consent', { detail: { map: true } }));
    loadMap();
  });

  // Reacciona al banner de cookies.
  document.addEventListener('rm:consent', (e) => {
    const detail = (e as CustomEvent).detail;
    if (detail?.map) loadMap();
  });

  // Estado inicial.
  if (hasMapConsent()) loadMap();
</script>
