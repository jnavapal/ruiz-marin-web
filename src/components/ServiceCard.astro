---
import type { Service } from '../data/site';
interface Props {
  service: Service;
  number?: number;
}
const { service, number } = Astro.props;
---

<a
  href={`/servicios/${service.slug}`}
  class="card group flex flex-col p-6 no-underline hover:shadow-card-hover focus-visible:shadow-card-hover"
>
  {
    number !== undefined && (
      <span class="font-serif text-sm font-semibold text-accent-600">
        {String(number).padStart(2, '0')}
      </span>
    )
  }
  <h3 class="mt-1 font-serif text-xl font-semibold text-ink group-hover:text-brand-800">
    {service.title}
  </h3>
  <p class="mt-3 flex-1 text-[0.975rem] leading-relaxed text-ink-soft">{service.excerpt}</p>
  <span class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-brand-700 group-hover:gap-2.5">
    Ver servicio
    <svg class="h-4 w-4 transition-all" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M4 10h12M11 5l5 5-5 5" />
    </svg>
  </span>
</a>
