---
/**
 * Bloque de credenciales y pertenencias profesionales (señal de confianza E-E-A-T).
 */
import { CREDENTIALS } from '../data/site';
interface Props {
  variant?: 'light' | 'plain';
  title?: string;
}
const { variant = 'plain', title = 'Acreditaciones y pertenencias profesionales' } = Astro.props;
const wrap = variant === 'light' ? 'bg-white' : 'bg-sand-100';
---

<section class={`${wrap} border-y border-sand-200`} aria-labelledby="cred-title">
  <div class="container-rm py-14">
    <div class="mx-auto max-w-2xl text-center">
      <div class="accent-rule mx-auto mb-4"></div>
      <h2 id="cred-title" class="text-h2">{title}</h2>
      <p class="mt-3 text-ink-soft">
        Todos nuestros trabajos están firmados por auditor de cuentas inscrito en el Registro
        Oficial de Auditores de Cuentas (ROAC) y respaldados por las principales corporaciones
        del sector.
      </p>
    </div>
    <ul class="mx-auto mt-10 grid max-w-5xl gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {
        CREDENTIALS.map((c) => (
          <li class="card flex flex-col items-center p-6 text-center">
            <span class="font-serif text-xl font-bold text-brand-800">{c.abbr}</span>
            <span class="mt-2 text-sm font-medium text-ink">{c.name}</span>
            <span class="mt-2 text-xs leading-relaxed text-ink-muted">{c.detail}</span>
          </li>
        ))
      }
    </ul>
  </div>
</section>
