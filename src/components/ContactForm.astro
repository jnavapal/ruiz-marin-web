---
import { SITE, SERVICES } from '../data/site';

// La access key es pública por diseño (se usa en el navegador). Se define en
// Cloudflare Pages → Environment variables como PUBLIC_FORM_KEY.
const FORM_KEY = import.meta.env.PUBLIC_FORM_KEY ?? '';
const redirectURL = `${SITE.url}/gracias`;
---

<form
  id="contact-form"
  action="https://api.web3forms.com/submit"
  method="POST"
  novalidate
  class="space-y-5"
>
  <!-- Web3Forms -->
  <input type="hidden" name="access_key" value={FORM_KEY} />
  <input type="hidden" name="subject" value="Nueva consulta desde ruizmarinauditores.com" />
  <input type="hidden" name="from_name" value="Web Ruiz & Marín" />
  <!-- Redirección de respaldo cuando el navegador no tiene JavaScript -->
  <input type="hidden" name="redirect" value={redirectURL} />
  <!-- Honeypot antispam (debe quedar vacío) -->
  <input type="checkbox" name="botcheck" tabindex="-1" aria-hidden="true" class="hidden" style="display:none" />

  <div class="grid gap-5 sm:grid-cols-2">
    <div>
      <label for="cf-nombre" class="mb-1.5 block text-sm font-medium text-ink">
        Nombre y apellidos <span class="text-brand-700" aria-hidden="true">*</span>
      </label>
      <input
        id="cf-nombre"
        name="nombre"
        type="text"
        required
        autocomplete="name"
        aria-required="true"
        aria-describedby="err-nombre"
        class="w-full rounded-md border border-sand-300 bg-white px-3.5 py-2.5 text-ink shadow-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-500/40"
      />
      <p id="err-nombre" class="mt-1 hidden text-sm text-red-700" role="alert"></p>
    </div>

    <div>
      <label for="cf-empresa" class="mb-1.5 block text-sm font-medium text-ink">Empresa</label>
      <input
        id="cf-empresa"
        name="empresa"
        type="text"
        autocomplete="organization"
        class="w-full rounded-md border border-sand-300 bg-white px-3.5 py-2.5 text-ink shadow-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-500/40"
      />
    </div>

    <div>
      <label for="cf-email" class="mb-1.5 block text-sm font-medium text-ink">
        Email <span class="text-brand-700" aria-hidden="true">*</span>
      </label>
      <input
        id="cf-email"
        name="email"
        type="email"
        required
        autocomplete="email"
        aria-required="true"
        aria-describedby="err-email"
        class="w-full rounded-md border border-sand-300 bg-white px-3.5 py-2.5 text-ink shadow-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-500/40"
      />
      <p id="err-email" class="mt-1 hidden text-sm text-red-700" role="alert"></p>
    </div>

    <div>
      <label for="cf-telefono" class="mb-1.5 block text-sm font-medium text-ink">Teléfono</label>
      <input
        id="cf-telefono"
        name="telefono"
        type="tel"
        autocomplete="tel"
        inputmode="tel"
        class="w-full rounded-md border border-sand-300 bg-white px-3.5 py-2.5 text-ink shadow-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-500/40"
      />
    </div>
  </div>

  <div>
    <label for="cf-servicio" class="mb-1.5 block text-sm font-medium text-ink">Servicio de interés</label>
    <select
      id="cf-servicio"
      name="servicio"
      class="w-full rounded-md border border-sand-300 bg-white px-3.5 py-2.5 text-ink shadow-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-500/40"
    >
      <option value="Consulta general">Consulta general</option>
      {SERVICES.map((s) => <option value={s.title}>{s.title}</option>)}
    </select>
  </div>

  <div>
    <label for="cf-mensaje" class="mb-1.5 block text-sm font-medium text-ink">
      Mensaje <span class="text-brand-700" aria-hidden="true">*</span>
    </label>
    <textarea
      id="cf-mensaje"
      name="mensaje"
      required
      rows="5"
      aria-required="true"
      aria-describedby="err-mensaje"
      class="w-full rounded-md border border-sand-300 bg-white px-3.5 py-2.5 text-ink shadow-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-500/40"
    ></textarea>
    <p id="err-mensaje" class="mt-1 hidden text-sm text-red-700" role="alert"></p>
  </div>

  <div>
    <div class="flex items-start gap-3">
      <input
        id="cf-privacidad"
        name="privacidad"
        type="checkbox"
        required
        aria-required="true"
        aria-describedby="err-privacidad"
        class="mt-1 h-5 w-5 shrink-0 accent-brand-700"
      />
      <label for="cf-privacidad" class="text-sm leading-relaxed text-ink-soft">
        He leído y acepto la
        <a href="/politica-de-privacidad" class="font-medium underline">política de privacidad</a>
        y consiento el tratamiento de mis datos para responder a mi consulta.
        <span class="text-brand-700" aria-hidden="true">*</span>
      </label>
    </div>
    <p id="err-privacidad" class="mt-1 hidden text-sm text-red-700" role="alert"></p>
  </div>

  <div class="flex flex-wrap items-center gap-4 pt-2">
    <button type="submit" class="btn btn-primary">Enviar consulta</button>
    <p class="text-xs text-ink-muted">
      Sus datos se tratan con confidencialidad y no se ceden a terceros.
    </p>
  </div>

  <p id="form-status" role="status" aria-live="polite" class="hidden rounded-md px-4 py-3 text-sm"></p>
</form>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  if (form) {
    const status = document.getElementById('form-status') as HTMLElement;

    const setError = (id: string, msg: string) => {
      const el = document.getElementById(`err-${id}`);
      const field = document.getElementById(`cf-${id}`);
      if (el) {
        el.textContent = msg;
        el.classList.toggle('hidden', !msg);
      }
      if (field) field.setAttribute('aria-invalid', msg ? 'true' : 'false');
    };

    const showStatus = (msg: string, ok: boolean) => {
      status.textContent = msg;
      status.className =
        'rounded-md px-4 py-3 text-sm ' +
        (ok ? 'bg-green-50 text-green-800 border border-green-200' : 'bg-red-50 text-red-800 border border-red-200');
    };

    const validate = () => {
      let valid = true;
      const get = (n: string) => form.elements.namedItem(n) as HTMLInputElement | HTMLTextAreaElement;
      ['nombre', 'email', 'mensaje', 'privacidad'].forEach((n) => setError(n, ''));

      const nombre = get('nombre').value.trim();
      const email = (get('email') as HTMLInputElement).value.trim();
      const mensaje = get('mensaje').value.trim();
      const privacidad = (get('privacidad') as HTMLInputElement).checked;

      if (!nombre) { setError('nombre', 'Indique su nombre.'); valid = false; }
      if (!email) { setError('email', 'Indique su email.'); valid = false; }
      else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { setError('email', 'Introduzca un email válido.'); valid = false; }
      if (!mensaje) { setError('mensaje', 'Escriba su consulta.'); valid = false; }
      if (!privacidad) { setError('privacidad', 'Debe aceptar la política de privacidad.'); valid = false; }
      return valid;
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!validate()) {
        const firstError = form.querySelector('[aria-invalid="true"]') as HTMLElement | null;
        firstError?.focus();
        return;
      }

      const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      submitBtn.disabled = true;
      submitBtn.textContent = 'Enviando…';

      try {
        const data = new FormData(form);
        const res = await fetch(form.action, {
          method: 'POST',
          body: data,
          headers: { Accept: 'application/json' },
        });
        const json = await res.json();
        if (res.ok && json.success) {
          form.reset();
          showStatus('Gracias por su consulta. La hemos recibido y le responderemos a la mayor brevedad.', true);
          status.focus?.();
        } else {
          showStatus(json.message || 'No se pudo enviar el formulario. Inténtelo de nuevo o escríbanos por email.', false);
        }
      } catch {
        showStatus('Error de conexión. Inténtelo de nuevo o escríbanos a info@ruizmarinauditores.com.', false);
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Enviar consulta';
      }
    });
  }
</script>
