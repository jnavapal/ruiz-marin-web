---
/**
 * Cabecera <head> reutilizable: SEO on-page, canonical, Open Graph, Twitter Cards,
 * favicons y metadatos por página. Cada página pasa su title/description únicos.
 */
import { SITE } from '../data/site';

interface Props {
  title: string;
  description: string;
  /** Ruta canónica explícita (por defecto, la URL actual normalizada). */
  canonicalPath?: string;
  /** Tipo Open Graph: 'website' | 'article'. */
  ogType?: 'website' | 'article';
  /** Imagen social (ruta absoluta del sitio). */
  image?: string;
  /** Evita indexación (p. ej. página de gracias). */
  noindex?: boolean;
  /** Fecha de publicación/actualización para artículos (ISO). */
  publishedTime?: string;
  modifiedTime?: string;
}

const {
  title,
  description,
  canonicalPath,
  ogType = 'website',
  image = '/og-image.png',
  noindex = false,
  publishedTime,
  modifiedTime,
} = Astro.props;

// Normaliza la ruta para el canonical (sin slash final salvo raíz).
const rawPath = canonicalPath ?? Astro.url.pathname;
const normalized =
  rawPath !== '/' && rawPath.endsWith('/') ? rawPath.slice(0, -1) : rawPath;
const canonicalURL = new URL(normalized, SITE.url).href;
const imageURL = new URL(image, SITE.url).href;

// Título completo: páginas internas añaden el nombre de marca; la home ya lo trae.
const fullTitle = title.includes(SITE.name) ? title : `${title} | ${SITE.name}`;
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />

<!-- SEO básico -->
<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />
{
  noindex ? (
    <meta name="robots" content="noindex, nofollow" />
  ) : (
    <meta name="robots" content="index, follow, max-image-preview:large" />
  )
}
<meta name="author" content={SITE.name} />
<meta name="theme-color" content="#2a405a" />
<meta name="format-detection" content="telephone=no" />

<!-- Idioma / geo -->
<meta name="language" content="es" />
<meta name="geo.region" content="ES-BU" />
<meta name="geo.placename" content="Burgos" />

<!-- Open Graph -->
<meta property="og:type" content={ogType} />
<meta property="og:site_name" content={SITE.name} />
<meta property="og:locale" content="es_ES" />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:image" content={imageURL} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={`${SITE.name} — auditores de cuentas`} />
{publishedTime && <meta property="article:published_time" content={publishedTime} />}
{modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}

<!-- Twitter Cards -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageURL} />
<meta name="twitter:image:alt" content={`${SITE.name} — auditores de cuentas`} />

<!-- Favicons / PWA -->
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="icon" href="/favicon-32.png" sizes="32x32" type="image/png" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />

<!-- Sitemap -->
<link rel="sitemap" href="/sitemap-index.xml" />

<!-- RSS de actualidad -->
<link
  rel="alternate"
  type="application/rss+xml"
  title={`Actualidad de ${SITE.name}`}
  href="/rss.xml"
/>
