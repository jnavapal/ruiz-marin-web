---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Gracias por su consulta | Ruiz & Marín';
const description = 'Hemos recibido su consulta. Le responderemos a la mayor brevedad.';
---

<BaseLayout title={title} description={description} noindex={true}>
  <section class="container-rm py-24 text-center">
    <div class="mx-auto max-w-xl">
      <span class="mx-auto inline-flex h-16 w-16 items-center justify-center rounded-full bg-green-100 text-green-700" aria-hidden="true">
        <svg class="h-8 w-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
      </span>
      <h1 class="mt-6 text-h1">Gracias por su consulta</h1>
      <p class="mt-4 text-lg text-ink-soft">
        Hemos recibido su mensaje correctamente. Le responderemos a la mayor brevedad, con total
        confidencialidad.
      </p>
      <div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
        <a href="/" class="btn btn-primary">Volver al inicio</a>
        <a href="/servicios" class="btn btn-secondary">Ver servicios</a>
      </div>
    </div>
  </section>
</BaseLayout>
