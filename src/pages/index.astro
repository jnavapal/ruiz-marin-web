---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import Credentials from '../components/Credentials.astro';
import CtaSection from '../components/CtaSection.astro';
import Faq from '../components/Faq.astro';
import { SERVICES, STATS } from '../data/site';
import { organizationSchema, accountingServiceSchema, faqSchema, graph } from '../lib/schema';

const title = 'Ruiz & Marín · Auditores de cuentas en Burgos (ROAC)';
const description =
  'Despacho de auditoría de cuentas en Burgos inscrito en el ROAC. Auditoría de cuentas anuales obligatoria y voluntaria, procedimientos acordados, deducciones fiscales y justificación de subvenciones de I+D, FEDER y CDTI.';

const homeFaqs = [
  {
    q: '¿Qué es un auditor inscrito en el ROAC?',
    a: 'Un auditor inscrito en el ROAC (Registro Oficial de Auditores de Cuentas) es el profesional o sociedad habilitado legalmente para auditar cuentas en España. La inscripción en este registro, dependiente del ICAC, es requisito imprescindible para firmar un informe de auditoría con validez legal.',
  },
  {
    q: '¿Atienden a empresas de toda España o solo de Burgos?',
    a: 'Tenemos nuestra sede en Burgos y atendemos a empresas y profesionales de toda España. La auditoría de cuentas y los informes de aseguramiento se realizan con la misma validez en cualquier provincia, combinando trabajo a distancia y presencial cuando el encargo lo requiere.',
  },
  {
    q: '¿Cómo solicito un presupuesto de auditoría?',
    a: 'Puede escribirnos desde la página de contacto o llamarnos. Tras conocer el tamaño de su empresa, el tipo de trabajo y los plazos, le confirmamos si la auditoría es obligatoria y le enviamos un presupuesto cerrado, sin compromiso y con total confidencialidad.',
  },
];

const schema = graph(organizationSchema(), accountingServiceSchema(), faqSchema(homeFaqs));

const ficha = [
  { k: 'Inscripción', v: 'Registro Oficial de Auditores de Cuentas (ROAC)' },
  { k: 'Sede', v: 'Burgos · Castilla y León' },
  { k: 'Ámbito', v: 'Toda España' },
  { k: 'A quién acompañamos', v: 'Pymes, fundaciones y profesionales' },
];

const metodo = [
  {
    title: 'Independencia',
    text: 'El núcleo de la auditoría. Mantenemos la objetividad y evitamos cualquier conflicto de interés en todos los encargos.',
  },
  {
    title: 'Rigor técnico',
    text: 'Trabajamos conforme a las Normas Internacionales de Auditoría (NIA-ES) y a la doctrina del ICAC, con control de calidad documentado.',
  },
  {
    title: 'Confidencialidad',
    text: 'Su información se trata bajo el secreto profesional del auditor. Nada se comparte sin su consentimiento.',
  },
  {
    title: 'Trato directo',
    text: 'Habla siempre con el socio que firma. Calendario realista y cumplimiento de los plazos legales de cuentas.',
  },
];
---

<BaseLayout title={title} description={description} schema={schema} canonicalPath="/">
  <!-- Hero -->
  <section class="border-b border-white/10 bg-brand-900 text-white">
    <div class="h-px w-full bg-gradient-to-r from-accent-500/0 via-accent-400/80 to-accent-500/0"></div>
    <div class="container-rm grid gap-14 py-20 md:py-28 lg:grid-cols-12 lg:gap-10">
      <div class="lg:col-span-7">
        <p class="flex items-center gap-3 text-[0.72rem] font-semibold uppercase tracking-[0.2em] text-accent-300">
          <span class="h-px w-7 bg-accent-400/70"></span>
          Auditoría de cuentas · ROAC · Burgos
        </p>
        <h1 class="mt-6 max-w-3xl font-serif text-display font-semibold leading-[1.05] text-white">
          Auditoría de cuentas con rigor, independencia y confidencialidad
        </h1>
        <p class="mt-7 max-w-2xl text-lg leading-relaxed text-sand-200/85">
          Acompañamos a pymes y profesionales a cumplir sus obligaciones de auditoría y a justificar
          subvenciones y deducciones con seguridad jurídica. Cada informe lo firma un auditor inscrito
          en el ROAC, conforme a la normativa vigente.
        </p>
        <div class="mt-9 flex flex-wrap items-center gap-x-7 gap-y-4">
          <a href="/contacto" class="btn bg-white text-brand-900 hover:bg-sand-100 hover:text-brand-900">
            Solicitar presupuesto
          </a>
          <a href="/servicios" class="group inline-flex items-center gap-2 font-semibold text-white no-underline">
            Ver los servicios
            <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 10h12M11 5l5 5-5 5" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Ficha del despacho -->
      <div class="lg:col-span-5 lg:pl-6">
        <dl class="divide-y divide-white/10 border-t border-white/15">
          {
            ficha.map((row) => (
              <div class="flex flex-col gap-1 py-4 sm:flex-row sm:items-baseline sm:gap-6">
                <dt class="w-44 shrink-0 text-[0.72rem] font-semibold uppercase tracking-[0.16em] text-sand-200/55">
                  {row.k}
                </dt>
                <dd class="text-[0.975rem] text-sand-100">{row.v}</dd>
              </div>
            ))
          }
        </dl>
      </div>
    </div>
  </section>

  <!-- Credenciales / confianza -->
  <Credentials />

  <!-- Servicios -->
  <section class="container-rm py-20 md:py-24" aria-labelledby="servicios-home">
    <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
      <div class="max-w-2xl">
        <p class="eyebrow">Áreas de trabajo</p>
        <h2 class="text-h2">Servicios de auditoría y aseguramiento</h2>
        <p class="mt-3 text-lg text-ink-soft">
          Para cada encargo le decimos qué es, cuándo lo necesita —el disparador legal o de negocio—
          y qué entregable recibe. Sin promesas vacías.
        </p>
      </div>
      <a href="/servicios" class="hidden shrink-0 items-center gap-2 font-semibold text-brand-700 no-underline hover:underline md:inline-flex">
        Índice completo
        <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 10h12M11 5l5 5-5 5" />
        </svg>
      </a>
    </div>
    <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {SERVICES.map((s, i) => <ServiceCard service={s} number={i + 1} />)}
    </div>
  </section>

  <!-- Método / por qué nosotros -->
  <section class="border-y border-sand-200 bg-white" aria-labelledby="metodo-home">
    <div class="container-rm grid gap-12 py-20 md:py-24 lg:grid-cols-12 lg:gap-16">
      <div class="lg:col-span-4">
        <p class="eyebrow">Cómo trabajamos</p>
        <h2 id="metodo-home" class="text-h2">Lo importante no es parecer moderno, sino ser fiable</h2>
        <p class="mt-4 text-ink-soft">
          En un sector regulado, la confianza se construye con independencia y método. Así entendemos
          el oficio.
        </p>
      </div>
      <div class="lg:col-span-8">
        <div class="grid gap-px overflow-hidden border border-sand-200 bg-sand-200 sm:grid-cols-2">
          {
            metodo.map((m) => (
              <div class="bg-white p-7">
                <h3 class="font-serif text-lg font-semibold text-ink">{m.title}</h3>
                <p class="mt-2 text-[0.95rem] leading-relaxed text-ink-soft">{m.text}</p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Cifras -->
  <section class="container-rm py-16" aria-label="Cifras del despacho">
    <dl class="grid divide-y divide-sand-200 sm:grid-cols-3 sm:divide-x sm:divide-y-0">
      {
        STATS.map((s) => (
          <div class="px-0 py-6 sm:px-8 sm:py-2 sm:first:pl-0">
            <dt class="sr-only">{s.label}</dt>
            <dd>
              <span class="font-serif text-4xl font-semibold text-brand-800">{s.value}</span>
              <span class="mt-1 block text-[0.95rem] font-medium text-ink">{s.label}</span>
              <span class="mt-1 block text-sm text-ink-muted">{s.detail}</span>
            </dd>
          </div>
        ))
      }
    </dl>
  </section>

  <!-- FAQ -->
  <section class="container-rm">
    <Faq faqs={homeFaqs} title="Preguntas frecuentes" id="faq-home" />
  </section>

  <CtaSection />
</BaseLayout>
