---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SERVICES } from '../data/site';
const title = 'Página no encontrada (404) | Ruiz & Marín';
const description = 'La página que busca no existe o ha cambiado de dirección.';
---

<BaseLayout title={title} description={description} noindex={true}>
  <section class="container-rm py-24 text-center">
    <div class="mx-auto max-w-xl">
      <p class="font-serif text-6xl font-bold text-brand-200">404</p>
      <h1 class="mt-4 text-h1">No encontramos esta página</h1>
      <p class="mt-4 text-lg text-ink-soft">
        Es posible que la dirección haya cambiado o que el enlace sea incorrecto. Puede volver al
        inicio o consultar nuestros servicios.
      </p>
      <div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
        <a href="/" class="btn btn-primary">Volver al inicio</a>
        <a href="/contacto" class="btn btn-secondary">Contactar</a>
      </div>
      <ul class="mt-10 flex flex-wrap justify-center gap-2">
        {
          SERVICES.map((s) => (
            <li>
              <a href={`/servicios/${s.slug}`} class="rounded-full border border-sand-300 px-3 py-1.5 text-sm text-ink-soft no-underline hover:bg-sand-100">
                {s.navTitle}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</BaseLayout>
