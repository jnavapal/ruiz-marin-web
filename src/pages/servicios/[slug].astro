---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Faq from '../../components/Faq.astro';
import CtaSection from '../../components/CtaSection.astro';
import { SERVICES, SITE } from '../../data/site';
import { SERVICES_CONTENT } from '../../data/services-content';
import { faqSchema, graph } from '../../lib/schema';

export function getStaticPaths() {
  return SERVICES.map((s) => ({
    params: { slug: s.slug },
    props: { slug: s.slug },
  }));
}

const { slug } = Astro.props as { slug: string };
const c = SERVICES_CONTENT[slug];
const meta = SERVICES.find((s) => s.slug === slug)!;
const canonical = new URL(`/servicios/${slug}`, SITE.url).href;

const related = SERVICES.filter((s) => s.slug !== slug);

const serviceSchema = {
  '@type': 'Service',
  serviceType: c.h1,
  name: c.h1,
  description: c.metaDescription,
  provider: { '@id': `${SITE.url}/#despacho` },
  areaServed: [
    { '@type': 'City', name: 'Burgos' },
    { '@type': 'Country', name: 'España' },
  ],
  url: canonical,
};

const schema = graph(serviceSchema, faqSchema(c.faqs));
---

<BaseLayout title={c.metaTitle} description={c.metaDescription} schema={schema}>
  <Breadcrumbs
    items={[
      { name: 'Servicios', path: '/servicios' },
      { name: meta.title, path: `/servicios/${slug}` },
    ]}
  />

  <article class="container-rm py-14 md:py-20">
    <div class="grid gap-12 lg:grid-cols-12">
      <!-- Contenido principal -->
      <div class="lg:col-span-8">
        <p class="inline-flex items-center gap-2 rounded-full bg-brand-50 px-3 py-1 text-sm font-medium text-brand-700">
          {c.forWhom}
        </p>
        <h1 class="mt-4 text-h1">{c.h1}</h1>
        <p class="mt-5 max-w-prose text-lg leading-relaxed text-ink-soft">{c.lead}</p>

        <!-- Definición (GEO/AIO) -->
        <aside class="mt-8 rounded-card border-l-4 border-accent-400 bg-sand-100 p-5">
          <p class="text-sm font-semibold uppercase tracking-wide text-accent-700">
            Definición · {c.definition.term}
          </p>
          <p class="mt-2 text-ink-soft">{c.definition.text}</p>
        </aside>

        <!-- Bloques de contenido -->
        {
          c.blocks.map((b) => (
            <section class="mt-12">
              <div class="accent-rule mb-4" />
              <h2 class="text-h2">{b.heading}</h2>
              <div class="prose-rm mt-4 max-w-prose" set:html={b.html} />
            </section>
          ))
        }

        <Faq faqs={c.faqs} id={`faq-${slug}`} />
      </div>

      <!-- Aside -->
      <aside class="lg:col-span-4">
        <div class="sticky top-28 space-y-6">
          <div class="card p-6">
            <h2 class="font-serif text-lg font-semibold text-ink">Solicite información</h2>
            <p class="mt-2 text-sm text-ink-soft">
              Le confirmamos el alcance y le enviamos un presupuesto cerrado, sin compromiso.
            </p>
            <a href="/contacto" class="btn btn-primary mt-4 w-full">Solicitar presupuesto</a>
            <a
              href={`tel:${SITE.phoneHref}`}
              class="btn btn-secondary mt-2 w-full"
            >
              {SITE.phoneDisplay}
            </a>
          </div>

          <nav class="card p-6" aria-label="Otros servicios">
            <h2 class="font-serif text-lg font-semibold text-ink">Otros servicios</h2>
            <ul class="mt-3 space-y-2">
              {
                related.map((r) => (
                  <li>
                    <a
                      href={`/servicios/${r.slug}`}
                      class="block rounded-md px-3 py-2 text-[0.95rem] text-ink-soft no-underline hover:bg-sand-100 hover:text-brand-800"
                    >
                      {r.navTitle}
                    </a>
                  </li>
                ))
              }
            </ul>
          </nav>
        </div>
      </aside>
    </div>
  </article>

  <CtaSection />
</BaseLayout>
